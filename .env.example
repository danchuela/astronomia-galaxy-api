# Copy this file to .env and set OPENAI_API_KEY. Set API_KEY if authentication is enabled.
# .env is ignored by git.

# HTTP API. API_KEY is optional when REQUIRE_API_KEY=false.
API_KEY=change-me
REQUIRE_API_KEY=false
ARTIFACT_DIR=artifacts
LOG_LEVEL=INFO

# LangSmith tracing, optional.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# OpenAI, required for natural-language parsing and the analysis agent.
OPENAI_API_KEY=
# Model used by the LangGraph analysis agent (tool-calling). Default: gpt-4.1
# AGENT_MODEL=gpt-4.1
# Model used by the NLU parser (enrich_request). Default: gpt-4.1
# OPENAI_PARSE_MODEL=gpt-4.1
# Model used for narrative summary generation. Default: gpt-4.1-mini
OPENAI_MODEL=gpt-4.1-mini

# Timeouts, in seconds.
# SKYVIEW_TIMEOUT=240
# SESAME_TIMEOUT=60
# SIMBAD_TIMEOUT=15
